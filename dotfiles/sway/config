exec gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark'
exec gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'

# Modifier
set $mod Mod4
set $term alacritty
set $menu wofi --show drun --style=$HOME/.config/wofi/style.css

# Monitör
output * bg /home/burak/kedi.jpg fill

# Keybindler
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym $mod+q kill
bindsym $mod+Shift+e exec swaymsg exit
bindsym $mod+Shift+r reload
bindsym $mod+Tab exec rofi -show window

# --- EKRAN GÖRÜNTÜSÜ KISAYOLLARI ---

# 1. Tüm Ekranı Al ve Resimler Klasörüne Kaydet (PrintScreen Tuşu)
bindsym Print exec grim ~/Resimler/Ekran_Goruntusu_$(date +%Y%m%d-%H%M%S).png

# 2. Sadece Seçilen Bir Bölgenin Görüntüsünü Al ve Kaydet (Win + Shift + S)
bindsym $mod+Shift+s exec grim -g "$(slurp)" ~/Resimler/Ekran_Goruntusu_$(date +%Y%m%d-%H%M%S).png

# 3. Sadece Seçilen Bölgeyi Al ve Doğrudan Panoya Kopyala (Dosya oluşturmaz, direkt Ctrl+V için)
bindsym $mod+Ctrl+s exec grim -g "$(slurp)" - | wl-copy

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5

# Layout
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle

# Swaylock
bindsym $mod+Escape exec gtklock -b 50

# Ekran görüntüsü
# bindsym Print exec grim ~/Pictures/$(date +%Y%m%d_%H%M%S).png
# bindsym $mod+Print exec grim -g "$(slurp)" ~/Pictures/$(date +%Y%m%d_%H%M%S).png

# Ses
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_SINK@ toggle

# Autostart
exec waybar


# Görünüm
default_border pixel 2
gaps inner 8
gaps outer 4

client.focused          #7aa2f7 #1a1a2e #c0caf5 #7aa2f7 #7aa2f7
client.unfocused        #3b4261 #1a1a2e #565f89 #3b4261 #3b4261

input "type:touchpad" {
  tap enabled
  natural_scroll enabled
}

input "type:keyboard" {
  xkb_layout tr
  xkb_model pc104
  xkb_variant ""
}
